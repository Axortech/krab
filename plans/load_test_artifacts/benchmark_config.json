{
  "version": 1,
  "description": "Benchmark target configuration for Krab and external framework comparisons",
  "frameworks": {
    "krab": {
      "display_name": "Krab (Rust)",
      "base_url_env": "KRAB_FRONTEND_BASE_URL",
      "default_base_url": "http://127.0.0.1:3000",
      "routes": {
        "home": "/",
        "blog_post": "/blog/benchmark-test",
        "api_status": "/api/status",
        "api_mutation": "/api/contact",
        "health": "/health"
      }
    },
