# ── Runtime environment ───────────────────────────────────────────────────────
KRAB_ENVIRONMENT=local          # dev | staging | prod | local
KRAB_SERVICE_NAME=krab          # overrides the crate-default service name
KRAB_HOST=127.0.0.1
KRAB_PORT=3000
KRAB_PUBLIC_BASE_URL=http://localhost:3000   # public origin for canonical URLs, og:url, robots sitemap link

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info                   # tracing filter (e.g. krab_core=debug,info)

# ── Authentication ────────────────────────────────────────────────────────────
KRAB_AUTH_MODE=jwt              # static | jwt | oidc
# SECURITY: You must set a unique secret token for your environment.
# Generate one with: openssl rand -hex 32
KRAB_BEARER_TOKEN=              # local/dev only when KRAB_AUTH_MODE=static
KRAB_SERVICE_AUTH_SCOPE=service:internal
KRAB_AUTH_PUBLIC_PATHS=         # optional: comma-separated list of paths to allow anonymously (e.g. /public/*,/assets/*)

# JWT / OIDC (required when KRAB_AUTH_MODE=jwt)
KRAB_OIDC_ISSUER=https://issuer.example.com
KRAB_OIDC_AUDIENCE=krab-api
# SECURITY (staging/prod): inline KRAB_JWT_SECRET / KRAB_JWT_KEYS_JSON is forbidden.
# Provide secret material via *_FILE or your vault reference envs.
# KRAB_JWT_SECRET_FILE=/run/secrets/krab_jwt_secret
# KRAB_JWT_KEYS_JSON_FILE=/run/secrets/krab_jwt_keys_json
# KRAB_JWT_SECRET_VAULT_REF=kv/data/krab/auth#jwt_secret
# KRAB_JWT_KEYS_JSON_VAULT_REF=kv/data/krab/auth#jwt_keys_json
# KRAB_AUTH_BOOTSTRAP_PASSWORD_FILE=/run/secrets/krab_bootstrap_password
# KRAB_AUTH_LOGIN_USERS_JSON_FILE=/run/secrets/krab_login_users_json
# KRAB_AUTH_BOOTSTRAP_PASSWORD_VAULT_REF=kv/data/krab/auth#bootstrap_password
# KRAB_AUTH_LOGIN_USERS_JSON_VAULT_REF=kv/data/krab/auth#login_users_json
# KRAB_JWT_REQUIRE_KID=false
# KRAB_JWT_PROVIDERS_JSON=[{"name":"default","issuer":"...","audience":"...","keys":{"default":"<base64-pem>"}}]

# ── Rate limiting ─────────────────────────────────────────────────────────────
KRAB_RATE_LIMIT_CAPACITY=120
KRAB_RATE_LIMIT_REFILL_PER_SEC=60
KRAB_REDIS_URL=redis://127.0.0.1:6379

# ── Database ──────────────────────────────────────────────────────────────────
KRAB_DB_DRIVER=postgres         # postgres | mysql | sqlite (mysql/sqlite adapters planned)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=krab
POSTGRES_DB_USERS=krab_users
DATABASE_URL=
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=1
DB_ACQUIRE_TIMEOUT_SECS=5
DB_MAX_LIFETIME_SECS=1800
DB_IDLE_TIMEOUT_SECS=600
DB_CONNECT_RETRIES=5
DB_CONNECT_RETRY_DELAY_MS=750

# ── Migration governance ──────────────────────────────────────────────────────
DB_MIGRATION_ALLOW_APPLY=true
DB_MIGRATION_FAILURE_POLICY=halt          # halt | continue_non_critical
DB_MIGRATION_RELEASE_ENVIRONMENTS=staging,prod
DB_MIGRATION_REQUIRE_REHEARSAL_IN_RELEASE=true

# ── Non-functional / performance tests ───────────────────────────────────────
# Set to 1 to enable NFT suite (load, spike, soak tests) in CI.
KRAB_NFT=0
