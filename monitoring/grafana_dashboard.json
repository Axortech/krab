{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Krab framework observability dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (job) (rate(krab_requests_total[1m]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 18 },
      "id": 7,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (job, protocol) (rate(krab_http_requests_by_protocol_total[1m]))",
          "legendFormat": "{{job}} {{protocol}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Protocol",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percent", "max": 100, "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 18 },
      "id": 8,
      "targets": [
        {
          "expr": "100 * sum by (job, protocol) (rate(krab_http_responses_by_protocol_total{class=\"5xx\"}[1m])) / (sum by (job, protocol) (rate(krab_http_requests_by_protocol_total[1m])) + 0.001)",
          "legendFormat": "{{job}} {{protocol}} 5xx%",
          "refId": "A"
        }
      ],
      "title": "Error Rate by Protocol",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 18 },
      "id": 9,
      "targets": [
        {
          "expr": "sum by (job) (rate(krab_http_requests_by_protocol_total{job=~\"users-rest|users-graphql|users-rpc\"}[1m]))",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "Users Split-Service Throughput",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percent", "max": 100, "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "100 * sum by (job) (rate(krab_http_responses_total{class=\"5xx\"}[1m])) / (sum by (job) (rate(krab_requests_total[1m])) + 0.001)",
          "legendFormat": "{{job}} 5xx%",
          "refId": "A"
        }
      ],
      "title": "Error Rate (5xx %)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ms" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "1000 * histogram_quantile(0.50, sum by (job, le) (rate(krab_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{job}} p50",
          "refId": "A"
        },
        {
          "expr": "1000 * histogram_quantile(0.95, sum by (job, le) (rate(krab_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{job}} p95",
          "refId": "B"
        },
        {
          "expr": "1000 * histogram_quantile(0.99, sum by (job, le) (rate(krab_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{job}} p99",
          "refId": "C"
        }
      ],
      "title": "Latency Percentiles",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Service Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] },
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }]
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 10 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "up{job=~\"krab_.*\"}",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "Service Up",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "none" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 10 },
      "id": 5,
      "targets": [
        {
          "expr": "krab_inflight_requests",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "In-Flight Requests",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 10 },
      "id": 6,
      "targets": [
        {
          "expr": "krab_uptime_seconds",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "Uptime (seconds)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["krab", "rust", "observability"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Krab Framework",
  "uid": "krab-framework-v1",
  "version": 1
}
